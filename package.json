{
  "name": "payunit-microservice",
  "version": "1.0.0",
  "description": "Reusable PayUnit payment microservice",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "build:prod": "npm install && tsc && npm prune --production",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "axios": "^1.6.0",
    "axios-retry": "^4.5.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "opossum": "^9.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.3.2",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/helmet": "^0.0.48",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
