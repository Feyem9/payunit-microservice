# PayUnit credentials (from your PayUnit dashboard)
PAYUNIT_API_USERNAME=your_api_username
PAYUNIT_API_PASSWORD=your_api_password
PAYUNIT_API_KEY=your_api_key
PAYUNIT_NOTIFY_URL=https://your-microservice.com/api/payment/callback
PAYUNIT_RETURN_URL=https://your-app.com/payment/success
PAYUNIT_CANCEL_URL=https://your-app.com/payment/cancel
PAYUNIT_MODE=test   # test, live, SANDBOX ou LIVE
PAYUNIT_BASE_URL=   # Optionnel — surcharge l'URL de base PayUnit (ex: https://gateway.payunit.net/api)
PAYUNIT_WEBHOOK_SECRET=your_webhook_secret_here

# Microservice security key (used by your apps to call this service)
MICROSERVICE_API_KEY=your_secret_key_here

# Server
PORT=3000
DB_PATH=./data/payunit.db   # Chemin vers la base SQLite

# CORS — liste des origines autorisées séparées par des virgules
# Exemple: https://online-learning.com,https://ecommerce.com,https://b2b.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
